# Trading wallet private key (0x-prefixed hex). Required.
POLYMARKET_PRIVATE_KEY=0x...

# Polygon RPC URL. Needed for on-chain merge calls (via alloy).
POLYGON_RPC_URL=https://polygon-rpc.com

# Set to "true" to run in paper trade mode (no real orders). Defaults to true.
PAPER_TRADE=true

# Maximum absolute directional exposure in USDC before quoting is paused.
MAX_EXPOSURE_USDC=200

# Order size in USDC per side (YES bid + NO bid). Start small for testing.
ORDER_SIZE_USDC=5

# Minimum spread posted on each side (in USDC). Must cover max taker fee (~0.0156 at p=0.50).
MIN_SPREAD=0.02

# Avellaneda-Stoikov risk aversion coefficient (γ). Higher = wider spreads.
RISK_AVERSION=0.5

# Absolute share exposure threshold that triggers inventory pause (same unit as MAX_EXPOSURE_USDC).
INVENTORY_PAUSE_THRESHOLD=100

# Polymarket WebSocket URL for market data.
POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Polymarket L2 API credentials (for authenticated fill notifications).
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Logging level. Set to "info" for production, "debug" for development.
RUST_LOG=info
